# Supabase project (Settings -> API in the Supabase dashboard)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe (test mode). Leave unset to run with billing stubbed out.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Server-side only secrets, used by Supabase Edge Functions — never expose in client code.
# Set these with `supabase secrets set` for deployed functions, or supabase/functions/.env for local dev.
# SUPABASE_SERVICE_ROLE_KEY=
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
